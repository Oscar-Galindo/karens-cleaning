---
/**
 * Benefits Grid — benefitsGridComponent
 * Centered heading, 4-col cards with rich inner UI illustrations
 */

import type { BenefitsGridComponentFields } from '@/lib/contentful';

export interface Props {
  fields: BenefitsGridComponentFields;
}

const { fields } = Astro.props;

const benefits = (fields.benefits || []).filter((b: any) => b?.fields);
---

<section class="max-w-7xl mx-auto px-6 py-32">
  {/* Header */}
  {fields.sectionTitle && (
    <div class="max-w-4xl mx-auto text-center mb-20">
      <h2 class="text-5xl md:text-6xl font-normal tracking-tight mb-8 text-[#1A1A1A]">
        {fields.sectionTitle}
      </h2>
      {fields.description && (
        <p class="text-xl text-[#1A1A1A]/70 leading-relaxed font-light">
          {fields.description}
        </p>
      )}
    </div>
  )}

  {/* Card Grid */}
  {benefits.length > 0 && (
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6">
      {benefits.map((benefit: any, i: number) => (
        <div class="bg-[#EDF1FA]/80 backdrop-blur-sm rounded-3xl p-8 flex flex-col h-full border border-[#1A1A1A]/5">
          {/* Title */}
          <h3 class="text-3xl font-normal mb-8 text-center tracking-tight text-[#1A1A1A]">
            {benefit.fields.title}
          </h3>

          {/* Inner UI Card — unique per card index */}
          {i === 0 && (
            <div class="bg-[#FAFFFE] rounded-2xl p-5 shadow-sm mb-8 flex-grow">
              <div class="flex justify-between items-center mb-4">
                <div class="flex items-center gap-3">
                  <svg class="w-6 h-6 text-[#102A52]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
                  <span class="text-lg text-[#1A1A1A]/70 font-light">Routine</span>
                </div>
                <span class="text-lg font-normal text-[#1A1A1A]">Weekly</span>
              </div>
              <div class="flex justify-between items-center mb-2">
                <div class="flex items-center gap-3">
                  <svg class="w-6 h-6 text-[#102A52]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5"/></svg>
                  <span class="text-lg text-[#1A1A1A]/70 font-light">Upkeep</span>
                </div>
                <span class="text-lg font-normal text-[#1A1A1A]">Biweekly</span>
              </div>
            </div>
          )}

          {i === 1 && (
            <div class="bg-[#FAFFFE] rounded-2xl p-5 shadow-sm mb-8 flex-grow">
              <div class="flex items-center justify-between mb-5">
                <span class="text-base font-normal text-[#1A1A1A]">Verification</span>
                <svg class="w-7 h-7 text-[#D4AF37]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
              </div>
              <div class="space-y-4">
                <div class="flex items-center gap-3 text-base text-[#1A1A1A]/70 font-light">
                  <svg class="w-5 h-5 text-[#102A52]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Background Checked
                </div>
                <div class="flex items-center gap-3 text-base text-[#1A1A1A]/70 font-light">
                  <svg class="w-5 h-5 text-[#102A52]" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                  Professional Staff
                </div>
              </div>
            </div>
          )}

          {i === 2 && (
            <div class="bg-[#FAFFFE] rounded-2xl p-5 shadow-sm mb-8 flex-grow">
              <div class="text-base text-[#1A1A1A]/60 mb-2 font-light">Family & leisure time</div>
              <div class="text-2xl font-normal mb-4 text-[#1A1A1A] tracking-tight">100% Yours</div>
              <div class="w-full bg-[#1A1A1A]/10 rounded-full h-2.5 mb-3">
                <div class="bg-[#102A52] h-2.5 rounded-full" style="width: 100%"></div>
              </div>
              <div class="flex justify-between text-sm text-[#1A1A1A]/60 font-light">
                <span>Current</span>
                <span>Goal</span>
              </div>
            </div>
          )}

          {i === 3 && (
            <div class="bg-[#FAFFFE] rounded-2xl p-5 shadow-sm mb-8 flex-grow space-y-4">
              <div class="flex items-center justify-between bg-[#1A1A1A]/5 p-3 rounded-xl">
                <div class="text-base font-normal text-[#1A1A1A]">Estimated Cost</div>
                <div class="text-base font-normal text-[#1A1A1A]">$XXX</div>
              </div>
              <div class="flex items-center justify-between p-3 rounded-xl">
                <div class="text-base text-[#1A1A1A]/60 font-light">Hidden Fees</div>
                <div class="text-base font-medium text-[#102A52]">0.00</div>
              </div>
            </div>
          )}

          {/* Description */}
          {benefit.fields.description && (
            <p class="text-lg text-[#1A1A1A]/70 leading-relaxed mt-auto font-light">
              {benefit.fields.description}
            </p>
          )}
        </div>
      ))}
    </div>
  )}
</section>
