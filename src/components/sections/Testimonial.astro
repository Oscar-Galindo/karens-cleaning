---
/**
 * Testimonial — testimonialComponent
 * Large gold quote mark, italic quote, star rating, author, carousel arrows
 */

import type { TestimonialComponentFields } from '@/lib/contentful';

export interface Props {
  fields: TestimonialComponentFields;
}

const { fields } = Astro.props;
---

<section class="py-32 px-6 relative overflow-hidden border-b border-[#1A1A1A]/5">
  {/* Decorative background shapes */}
  <div class="absolute left-0 top-1/2 -translate-y-1/2 w-1/3 h-[600px] bg-[#F0FAFA]/60 rounded-r-full hidden md:block z-0"></div>
  <div class="absolute left-[-20%] top-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-[#F0FAFA]/60 rounded-full hidden md:block z-0"></div>

  <div class="max-w-6xl mx-auto flex items-center justify-between relative z-10">
    {/* Left Arrow */}
    <button class="w-14 h-14 bg-[#FAFFFE] rounded-full border border-[#1A1A1A]/10 shadow-sm flex items-center justify-center hover:bg-[#F0FAFA] flex-shrink-0 z-20 transition-colors">
      <svg class="w-6 h-6 text-[#1A1A1A]/60" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M10.5 19.5L3 12m0 0l7.5-7.5M3 12h18"/></svg>
    </button>

    <div class="flex-grow flex flex-col md:flex-row items-center justify-center px-8 md:px-20 gap-12 text-center md:text-left">
      {/* Large decorative quote mark */}
      <div class="text-[10rem] leading-none text-[#D4AF37]/40 font-serif hidden md:block self-start mt-[-40px]">
        &ldquo;
      </div>

      <div class="max-w-3xl">
        {/* Quote text */}
        <p class="text-4xl md:text-5xl font-light tracking-tight text-[#1A1A1A] mb-10 leading-snug">
          &ldquo; {fields.quote} &rdquo;
        </p>

        {/* Author */}
        <div>
          {fields.author && (
            <div class="font-normal text-xl text-[#00C4CC] mb-2">{fields.author}</div>
          )}
          {/* Stars */}
          <div class="flex items-center gap-2 justify-center md:justify-start">
            <svg class="w-6 h-6 text-[#D4AF37]" fill="currentColor" viewBox="0 0 20 20">
              <path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/>
            </svg>
            {fields.authorTitle && (
              <span class="font-normal text-lg text-[#1A1A1A]/80">{fields.authorTitle}</span>
            )}
          </div>
        </div>
      </div>
    </div>

    {/* Right Arrow */}
    <button class="w-14 h-14 bg-[#FAFFFE] rounded-full border border-[#1A1A1A]/10 shadow-sm flex items-center justify-center hover:bg-[#F0FAFA] flex-shrink-0 z-20 transition-colors">
      <svg class="w-6 h-6 text-[#1A1A1A]/60" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5L21 12m0 0l-7.5 7.5M21 12H3"/></svg>
    </button>
  </div>
</section>
