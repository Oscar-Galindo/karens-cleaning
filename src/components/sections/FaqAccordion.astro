---
/**
 * FAQ Accordion — faqComponent
 * Centered title, rounded card accordions with circular toggle icons
 */

import type { FaqComponentFields } from '@/lib/contentful';

export interface Props {
  fields: FaqComponentFields;
}

const { fields } = Astro.props;

const items = (fields.faqs || []).filter((item: any) => item?.fields);
---

<section class="py-24 px-6 border-t border-zinc-200/50 bg-white">
  <div class="max-w-3xl mx-auto">
    {/* Header */}
    {fields.sectionTitle && (
      <h2 class="text-3xl font-medium tracking-tighter text-center text-zinc-900 mb-12">
        {fields.sectionTitle}
      </h2>
    )}

    {/* Accordion Items */}
    {items.length > 0 && (
      <div class="space-y-4">
        {items.map((item: any) => (
          <details class="group bg-white rounded-2xl ring-1 ring-zinc-200/60 overflow-hidden transition-all hover:ring-zinc-300 shadow-sm">
            <summary class="flex cursor-pointer items-center justify-between p-6 text-zinc-900 font-medium text-base select-none [&::-webkit-details-marker]:hidden list-none">
              <span>{item.fields.question}</span>
              <span class="relative flex h-8 w-8 items-center justify-center rounded-full bg-zinc-50 text-zinc-500 group-open:bg-zinc-900 group-open:text-white transition-colors border border-zinc-200 group-open:border-zinc-900 shrink-0 ml-4">
                <iconify-icon icon="solar:alt-arrow-down-linear" class="transition-transform duration-300 group-open:-rotate-180"></iconify-icon>
              </span>
            </summary>
            <div class="px-6 pb-6 text-zinc-500 text-sm font-light leading-relaxed border-t border-zinc-100 pt-4">
              {item.fields.answer}
            </div>
          </details>
        ))}
      </div>
    )}
  </div>
</section>
