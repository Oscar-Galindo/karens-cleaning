---
/**
 * Site Footer — Karen's Cleaning
 * Dark green (#0D2626) footer with logo, social icons, link columns, legal
 * All data from Site Settings → Footer reference (single source of truth)
 */

import { getSiteSettings } from '@/lib/contentful';

const settings = await getSiteSettings();
const footer = settings?.footer;

const companyName = footer?.companyName || settings?.logoText || "Karen's";
const logoUrl = settings?.logoUrl || null;
const logoText = settings?.logoText || "Karen's";

// Social links with icon mapping
const socialIconMap: Record<string, string> = {
  youtube: 'solar:play-stream-linear',
  tiktok: 'solar:hashtag-linear',
  instagram: 'solar:camera-linear',
  facebook: 'solar:play-stream-linear',
  twitter: 'solar:hashtag-linear',
  linkedin: 'solar:letter-linear',
};

const socialLinks = (footer?.socialLinks || []).map((s) => ({
  ...s,
  icon: socialIconMap[s.platform?.toLowerCase()] || 'solar:link-linear',
}));

// Menu columns with fallbacks
const pagesCol = footer?.aboutMenuItems.length
  ? footer.aboutMenuItems
  : [
      { label: 'Home', link: '/', openInNewTab: false },
      { label: 'Our Services', link: '/services', openInNewTab: false },
      { label: 'About', link: '/about', openInNewTab: false },
    ];

const ctaCol = footer?.getStartedItems.length
  ? footer.getStartedItems
  : [{ label: 'Get Your Estimate', link: '/book', openInNewTab: false }];

const legalCol = footer?.legalLinks.length
  ? footer.legalLinks
  : [
      { label: 'Privacy Policy', link: '/privacy' },
      { label: 'Terms of Use', link: '/terms' },
    ];

const copyrightText = footer?.copyrightText || `© ${new Date().getFullYear()} Karen's Cleaning Services. All rights reserved.`;
---

<footer id="contact" class="bg-[#0D2626] pt-24 pb-12 px-6">
  <div class="max-w-7xl mx-auto">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-12 mb-20">

      {/* Logo & Socials */}
      <div class="md:col-span-1">
        <a href="/" class="flex items-center text-[#00C4CC] mb-8">
          {logoUrl ? (
            <img src={logoUrl} alt={companyName} class="h-12 w-auto brightness-0 invert" />
          ) : (
            <span class="text-5xl font-medium tracking-tight">{logoText}</span>
          )}
        </a>
        {socialLinks.length > 0 && (
          <div class="flex items-center gap-4">
            {socialLinks.map((social) => (
              <a
                href={social.url}
                target="_blank"
                rel="noopener noreferrer"
                class="w-12 h-12 rounded-full border border-[#F8F8F8]/20 flex items-center justify-center text-[#00C4CC] hover:bg-[#F8F8F8]/10 transition-colors"
                aria-label={social.platform}
              >
                <iconify-icon icon={social.icon} class="text-lg"></iconify-icon>
              </a>
            ))}
          </div>
        )}
      </div>

      {/* Pages */}
      <div>
        <h4 class="text-lg font-normal tracking-tight text-[#F8F8F8] mb-8">Pages</h4>
        <ul class="space-y-5 text-lg text-[#F8F8F8]/70 font-light">
          {pagesCol.map((item) => (
            <li>
              <a
                href={item.link}
                target={item.openInNewTab ? '_blank' : undefined}
                rel={item.openInNewTab ? 'noopener noreferrer' : undefined}
                class="hover:text-[#00C4CC] transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Get Started */}
      <div>
        <h4 class="text-lg font-normal tracking-tight text-[#F8F8F8] mb-8">Get Started</h4>
        <ul class="space-y-5 text-lg text-[#F8F8F8]/70 font-light">
          {ctaCol.map((item) => (
            <li>
              <a
                href={item.link}
                target={item.openInNewTab ? '_blank' : undefined}
                rel={item.openInNewTab ? 'noopener noreferrer' : undefined}
                class="text-[#00C4CC] font-normal hover:text-[#00898F] transition-colors"
              >
                {item.label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      {/* Tagline */}
      <div>
        {footer?.tagline && (
          <p class="text-lg text-[#F8F8F8]/50 font-light leading-relaxed">{footer.tagline}</p>
        )}
      </div>
    </div>

    {/* Bottom bar */}
    <div class="border-t border-[#F8F8F8]/10 pt-10 flex flex-col md:flex-row justify-between items-center gap-6 text-base text-[#F8F8F8]/50 font-light">
      <p>{copyrightText}</p>
      {legalCol.length > 0 && (
        <div class="flex gap-8">
          {legalCol.map((item) => (
            <a href={item.link} class="hover:text-[#00C4CC] transition-colors">{item.label}</a>
          ))}
        </div>
      )}
    </div>
  </div>
</footer>
