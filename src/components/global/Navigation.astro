---
/**
 * Navigation — Karen's Cleaning
 * Sticky header: teal "Karen's" logo, centered links, dark CTA pill button
 */

import { getSiteNavigation, getAssetUrl } from '@/lib/contentful';

export interface Props {
  currentPath?: string;
}

const { currentPath = '' } = Astro.props;

const nav = await getSiteNavigation();

const defaultNav = {
  menuItems: [
    { label: 'Home', url: '/' },
    { label: 'Our Services', url: '#services' },
    { label: 'About', url: '#about' },
  ],
  ctaButton: {
    text: 'Get Your Estimate',
    url: import.meta.env.BOOKING_URL || '#contact',
    external: false,
  },
};

const menuItems = nav?.menuItems || defaultNav.menuItems;
const ctaButton = nav?.ctaButton || defaultNav.ctaButton;

function isActive(url: string): boolean {
  if (url.startsWith('#')) return false;
  if (url === '/') return currentPath === '/';
  return currentPath === url || currentPath.startsWith(url + '/');
}
---

<header class="w-full sticky top-0 z-50 border-b border-[#1A1A1A]/5" style="background: rgba(250,255,254,0.8); backdrop-filter: blur(12px); -webkit-backdrop-filter: blur(12px);">
  <div class="max-w-7xl mx-auto px-6 h-24 flex items-center justify-between">

    <!-- Logo -->
    <a href="/" class="flex items-center text-[#00C4CC]">
      <span class="text-4xl font-medium tracking-tight">Karen's</span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-10">
      {menuItems.map((item) => (
        <a
          href={item.url}
          class:list={[
            'text-lg font-normal transition-colors',
            isActive(item.url) ? 'text-[#00C4CC]' : 'text-[#1A1A1A] hover:text-[#00C4CC]'
          ]}
        >
          {item.label}
        </a>
      ))}
    </nav>

    <!-- CTA -->
    <div class="hidden md:flex items-center">
      <a
        href={ctaButton.url}
        target={ctaButton.external ? '_blank' : undefined}
        rel={ctaButton.external ? 'noopener noreferrer' : undefined}
        class="bg-[#1A1A1A] text-[#FAFFFE] px-6 py-3 rounded-full text-lg font-normal hover:bg-[#333333] transition-all shadow-md hover:shadow-lg hover:-translate-y-0.5"
      >
        {ctaButton.text}
      </a>
    </div>

    <!-- Mobile Menu Button -->
    <button
      id="mobile-menu-btn"
      class="md:hidden p-2 -mr-2 text-[#1A1A1A]"
      aria-label="Toggle menu"
      aria-expanded="false"
    >
      <svg class="menu-open w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
      </svg>
      <svg class="menu-close hidden w-7 h-7" fill="none" stroke="currentColor" stroke-width="1.5" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
      </svg>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div id="mobile-menu" class="md:hidden hidden absolute top-24 left-0 w-full border-b border-[#1A1A1A]/5 shadow-xl px-6 py-2 z-50" style="background: #FAFFFE;">
    <div class="flex flex-col space-y-5 pt-6 pb-6">
      {menuItems.map((item) => (
        <a
          href={item.url}
          class:list={[
            'text-xl font-normal transition-colors',
            isActive(item.url) ? 'text-[#00C4CC]' : 'text-[#1A1A1A] hover:text-[#00C4CC]'
          ]}
        >
          {item.label}
        </a>
      ))}
    </div>
    <div class="pb-6">
      <a
        href={ctaButton.url}
        class="block text-center bg-[#1A1A1A] text-[#FAFFFE] px-4 py-4 rounded-full text-xl font-normal tracking-tight hover:bg-[#333333] transition-all shadow-md"
      >
        {ctaButton.text}
      </a>
    </div>
  </div>
</header>

<script>
  const menuBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const menuOpenIcon = menuBtn?.querySelector('.menu-open');
  const menuCloseIcon = menuBtn?.querySelector('.menu-close');

  menuBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    menuBtn.setAttribute('aria-expanded', String(isOpen));
    menuOpenIcon?.classList.toggle('hidden', isOpen);
    menuCloseIcon?.classList.toggle('hidden', !isOpen);
  });

  mobileMenu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      menuBtn?.setAttribute('aria-expanded', 'false');
      menuOpenIcon?.classList.remove('hidden');
      menuCloseIcon?.classList.add('hidden');
    });
  });
</script>
