---
/**
 * Homepage — Karen's Cleaning
 * Fetches the "home" page from Contentful and renders component sections
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/global/Navigation.astro';
import SiteFooter from '@/components/global/SiteFooter.astro';
import SectionRendererV2 from '@/components/SectionRendererV2.astro';
import { getHomePageData, getAssetUrl } from '@/lib/contentful';

const page = await getHomePageData();

const seoTitle = page?.seo?.metaTitle || "Karen's Cleaning — Trusted Home Cleaning Services";
const seoDescription = page?.seo?.metaDescription || "Professional, reliable house cleaning services. Book your free estimate today.";
const seoImage = page?.seo?.ogImage ? getAssetUrl(page.seo.ogImage) : undefined;

const hasContentWithImage = page?.components.some(c => c.contentType === 'contentWithImageComponent') ?? false;
---

<BaseLayout
  title={seoTitle}
  description={seoDescription}
  image={seoImage || undefined}
>
  <Navigation currentPath="/" />

  {page && page.components.length > 0 ? (
    page.components.map((component, index) => {
      const isHero = component.contentType === 'heroComponent';
      const isBeforeFaq = index < page.components.length - 1 
        && page.components[index + 1]?.contentType === 'faqComponent'
        && !hasContentWithImage;

      return (
        <>
          <SectionRendererV2 component={component} index={index} />

          {/* Trust Bar — inserted right after hero */}
          {isHero && (
            <div class="bg-[#102A52] py-6 px-6 border-y border-[#1A1A1A]/5 relative z-20">
              <p class="max-w-7xl mx-auto text-[#F8F8F8] text-base md:text-lg font-normal flex flex-wrap justify-center items-center gap-x-4 gap-y-3 text-center">
                <span>Professional & background-checked</span>
                <span class="hidden md:inline text-[#102A52]">•</span>
                <span>Locally owned and operated</span>
                <span class="hidden lg:inline text-[#102A52]">•</span>
                <span>House, move-in/out & post-construction</span>
                <span class="hidden md:inline text-[#102A52]">•</span>
                <span>Serving Ocean, NJ and surrounding areas</span>
              </p>
            </div>
          )}

          {/* Content With Image fallback — inserted before FAQ if Contentful entry missing */}
          {isBeforeFaq && (
            <section id="about" class="py-32 px-6 border-b border-[#1A1A1A]/5">
              <div class="max-w-7xl mx-auto flex flex-col md:flex-row items-center gap-20">
                <div class="w-full md:w-5/12 relative">
                  <div class="absolute inset-5 border border-[#102A52]/20 rounded-[2.5rem] z-0"></div>
                  <img
                    src="https://img.freepik.com/free-photo/woman-apron-cleaning-table-kitchen_259150-59470.jpg?w=2000"
                    alt="Local Trusted Cleaning"
                    class="w-full aspect-square md:aspect-[4/5] object-cover rounded-3xl shadow-lg relative z-10"
                    loading="lazy"
                  />
                </div>
                <div class="w-full md:w-7/12">
                  <h2 class="text-5xl md:text-6xl font-normal tracking-tight mb-10 text-[#1A1A1A]">
                    Local, trusted, and built on doing good work.
                  </h2>
                  <div class="space-y-8 text-xl text-[#1A1A1A]/70 leading-relaxed font-light">
                    <p>
                      Karen's Cleaning Services was built around one simple idea: families deserve a clean home without having to manage one more thing. We're a local business rooted in Ocean, NJ, and we treat every home we clean the way we'd want ours treated — thoroughly, respectfully, and with attention to the details that actually matter.
                    </p>
                    <p>
                      When you book with us, you're not getting a franchise or a revolving door of strangers. You're getting a consistent team that shows up, does the work, and takes your home seriously.
                    </p>
                  </div>
                </div>
              </div>
            </section>
          )}
        </>
      );
    })
  ) : (
    <section class="relative pt-24 pb-16 md:pt-32 md:pb-24 flex flex-col items-center justify-center text-center px-6">
      <h1 class="text-6xl md:text-7xl lg:text-8xl font-normal tracking-tight leading-[1.1] mb-6 text-[#1A1A1A] max-w-7xl">
        Your home, clean and ready.<br class="hidden md:block" />
        <span class="text-transparent bg-clip-text" style="background-image: linear-gradient(to right, #102A52, #1E3F6E); -webkit-background-clip: text;">Without the hassle.</span>
      </h1>
      <p class="text-2xl md:text-3xl text-[#1A1A1A]/70 mb-10 max-w-5xl leading-relaxed font-light">
        Karen's Cleaning Services handles the mess so busy families can actually enjoy their weekends.
      </p>
      <a
        href="#contact"
        class="bg-[#1A1A1A] text-[#FAFFFE] px-8 py-4 rounded-full text-xl font-normal hover:bg-[#333333] transition-all shadow-lg"
      >
        Get Your Estimate
      </a>
    </section>
  )}

  <SiteFooter />
</BaseLayout>
