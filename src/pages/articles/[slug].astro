---
/**
 * Article Detail Page
 * Two-column layout: main content + related articles sidebar
 */

import BaseLayout from '@/layouts/BaseLayout.astro';
import Navigation from '@/components/global/Navigation.astro';
import SiteFooter from '@/components/global/SiteFooter.astro';
import { getArticle, getArticles } from '@/lib/contentful';
import { documentToHtmlString } from '@contentful/rich-text-html-renderer';
import { BLOCKS, INLINES } from '@contentful/rich-text-types';
import { CloudinaryPresets, getCloudinaryUrl } from '@/lib/cloudinary';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/articles');

const article = await getArticle(slug);
if (!article) return Astro.redirect('/404');

// Get related articles: use explicit ones or fall back to same-category articles
let related = article.relatedArticles || [];
if (related.length === 0) {
  const { articles: categoryArticles } = await getArticles({
    categorySlug: article.category.slug,
    limit: 4,
  });
  related = categoryArticles.filter((a) => a.slug !== slug).slice(0, 3);
}

const formattedDate = new Date(article.publishDate).toLocaleDateString('en-US', {
  month: 'short',
  day: 'numeric',
  year: 'numeric',
});

const renderOptions = {
  renderNode: {
    [BLOCKS.PARAGRAPH]: (node: any, next: any) =>
      `<p class="mb-6 leading-relaxed text-neutral-700">${next(node.content)}</p>`,
    [BLOCKS.HEADING_2]: (node: any, next: any) =>
      `<h2 class="text-2xl md:text-3xl font-semibold text-black mt-12 mb-4">${next(node.content)}</h2>`,
    [BLOCKS.HEADING_3]: (node: any, next: any) =>
      `<h3 class="text-xl md:text-2xl font-semibold text-black mt-10 mb-3">${next(node.content)}</h3>`,
    [BLOCKS.HEADING_4]: (node: any, next: any) =>
      `<h4 class="text-lg font-semibold text-black mt-8 mb-3">${next(node.content)}</h4>`,
    [BLOCKS.UL_LIST]: (node: any, next: any) =>
      `<ul class="mb-6 space-y-2 pl-1">${next(node.content)}</ul>`,
    [BLOCKS.OL_LIST]: (node: any, next: any) =>
      `<ol class="mb-6 space-y-2 pl-1 list-decimal list-inside">${next(node.content)}</ol>`,
    [BLOCKS.LIST_ITEM]: (node: any, next: any) =>
      `<li class="flex items-start gap-2 text-neutral-700"><span class="mt-2 w-1.5 h-1.5 rounded-full bg-neutral-400 shrink-0"></span><span>${next(node.content)}</span></li>`,
    [BLOCKS.QUOTE]: (node: any, next: any) =>
      `<blockquote class="my-8 pl-6 border-l-2 border-black"><div class="text-lg md:text-xl italic text-black font-medium leading-relaxed">${next(node.content)}</div></blockquote>`,
    [BLOCKS.HR]: () =>
      `<hr class="my-10 border-neutral-200" />`,
    [BLOCKS.EMBEDDED_ASSET]: (node: any) => {
      const url = node.data?.target?.fields?.file?.url;
      const alt = node.data?.target?.fields?.title || '';
      if (!url) return '';
      const src = url.startsWith('//') ? `https:${url}` : url;
      const optimized = getCloudinaryUrl(src, { width: 1280, quality: 'auto:good', format: 'auto' });
      return `<figure class="my-8"><img src="${optimized}" alt="${alt}" class="w-full rounded-xl" loading="lazy" /></figure>`;
    },
    [INLINES.HYPERLINK]: (node: any, next: any) =>
      `<a href="${node.data.uri}" class="underline text-black hover:text-neutral-600 transition-colors" target="${node.data.uri.startsWith('http') ? '_blank' : '_self'}" rel="${node.data.uri.startsWith('http') ? 'noopener noreferrer' : ''}">${next(node.content)}</a>`,
  },
};

let bodyHtml = '';
try {
  bodyHtml = article.body ? documentToHtmlString(article.body, renderOptions) : '';
} catch {
  bodyHtml = '<p class="text-neutral-500">Content could not be rendered.</p>';
}

const placeholderImg = 'https://images.unsplash.com/photo-1454165804606-c3d57bc86b40?w=800&h=500&fit=crop&auto=format';
const rawHeroImg = article.featuredImage?.url || placeholderImg;
const heroImg = CloudinaryPresets.hero(rawHeroImg, 1280);

const footerContent = {
  logoUrl: '/logo.png',
  tagline: 'Hand it off. It\'s handled.',
};

const pageTitle = `${article.title} | Your Site Name`;
const pageDescription = article.excerpt || '';
---

<BaseLayout title={pageTitle} description={pageDescription}>
  <Navigation currentPath="/articles" />

  <article class="w-full px-6 md:px-12 pt-8 pb-20 bg-white">
    <div class="max-w-6xl mx-auto">

      <!-- Back Link -->
      <a href="/articles" class="inline-flex items-center gap-1 text-sm text-neutral-500 hover:text-black transition-colors mb-10">
        ← Back to Insights
      </a>

      <div class="grid lg:grid-cols-[1fr_320px] gap-16">

        <!-- Main Content -->
        <div class="min-w-0">

          <!-- Meta -->
          <div class="flex items-center gap-3 mb-6">
            <span class="text-xs font-semibold tracking-widest uppercase text-neutral-500">
              {article.category.name}
            </span>
            <span class="text-neutral-400">·</span>
            <span class="text-sm text-neutral-500">{formattedDate}</span>
            <span class="text-neutral-400">·</span>
            <span class="text-sm text-neutral-500">{article.readingTime} min read</span>
          </div>

          <!-- Title -->
          <h1 class="text-3xl md:text-4xl lg:text-5xl font-semibold tracking-tight text-black mb-8 leading-tight">
            {article.title}
          </h1>

          <!-- Featured Image -->
          <div class="mb-10 rounded-xl overflow-hidden">
            <img
              src={heroImg}
              alt={article.featuredImage?.alt || article.title}
              class="w-full aspect-[16/9] object-cover"
            />
          </div>

          <!-- Excerpt as lead paragraph -->
          <p class="text-lg md:text-xl font-medium text-black leading-relaxed mb-8">
            {article.excerpt}
          </p>

          <!-- Body -->
          <div class="article-body" set:html={bodyHtml} />

          <!-- Author Bar -->
          <div class="mt-16 pt-8 border-t border-neutral-200 flex items-center justify-between">
            <div class="flex items-center gap-4">
              <div class="w-10 h-10 rounded-full bg-neutral-100 flex items-center justify-center border border-neutral-200 overflow-hidden">
                <img
                  src={CloudinaryPresets.avatar(footerContent.logoUrl, 48)}
                  alt="Your Site"
                  class="w-6 h-6 object-contain"
                />
              </div>
              <div>
                <p class="text-sm font-semibold text-black">Your Site</p>
                <p class="text-xs text-neutral-500">Operations Team</p>
              </div>
            </div>
            <div class="flex items-center gap-3">
              <span class="text-xs text-neutral-400">Share</span>
              <button
                onclick={`navigator.clipboard.writeText(window.location.href)`}
                class="p-2 rounded-full hover:bg-neutral-100 transition-colors"
                aria-label="Copy link"
              >
                <iconify-icon icon="solar:link-linear" width="16" class="text-neutral-500"></iconify-icon>
              </button>
              <a
                href={`https://twitter.com/intent/tweet?url=${encodeURIComponent(`https://yourdomain.com/articles/${slug}`)}&text=${encodeURIComponent(article.title)}`}
                target="_blank"
                rel="noopener noreferrer"
                class="p-2 rounded-full hover:bg-neutral-100 transition-colors"
                aria-label="Share on X"
              >
                <iconify-icon icon="ri:twitter-x-line" width="16" class="text-neutral-500"></iconify-icon>
              </a>
            </div>
          </div>
        </div>

        <!-- Sidebar -->
        <aside class="hidden lg:block">
          <div class="sticky top-28">
            <h2 class="text-lg font-semibold text-black mb-6">Related Articles</h2>
            <div class="space-y-6">
              {related.length > 0 ? (
                related.map((r) => {
                  const rDate = new Date(r.publishDate).toLocaleDateString('en-US', {
                    month: 'short',
                    day: 'numeric',
                    year: 'numeric',
                  });
                  return (
                    <a href={`/articles/${r.slug}`} class="group block pb-6 border-b border-neutral-100 last:border-0">
                      <div class="flex items-center gap-2 mb-2">
                        <span class="text-xs font-semibold tracking-widest uppercase text-neutral-400">
                          {r.category?.name || ''}
                        </span>
                        <span class="text-neutral-400">·</span>
                        <span class="text-xs text-neutral-500">{r.readingTime} min read</span>
                      </div>
                      <p class="text-sm font-semibold text-black group-hover:text-neutral-600 transition-colors leading-snug">
                        {r.title}
                      </p>
                    </a>
                  );
                })
              ) : (
                <p class="text-sm text-neutral-400">No related articles yet.</p>
              )}
            </div>
          </div>
        </aside>

      </div>
    </div>
  </article>

  <SiteFooter
    logoUrl={footerContent.logoUrl}
    tagline={footerContent.tagline}
  />
</BaseLayout>
